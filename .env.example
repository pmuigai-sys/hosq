VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Supabase Service Role Key (KEEP SECRET! Only use server-side)
# Required for admin operations like confirming user emails
# Find this in: Supabase Dashboard → Settings → API → service_role key
VITE_SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# BulkSMS.com configuration (set in Supabase Edge Function Secrets)
# BULKSMS_TOKEN_ID=your_bulksms_token_id
# BULKSMS_TOKEN_SECRET=your_bulksms_token_secret
